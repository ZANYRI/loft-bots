{
  "title": "Loft Bots",
  "uid": "loft-bots-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[5m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "{{path}}" }
      ]
    },
    {
      "id": 3,
      "title": "Bot updates/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "sum(rate(bot_updates_total[5m])) by (bot)", "legendFormat": "{{bot}}" }
      ]
    },
    {
      "id": 4,
      "title": "Bot errors/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(bot_errors_total[5m])) by (bot)", "legendFormat": "{{bot}}" }
      ]
    },
    {
      "id": 5,
      "title": "Orders created/hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(increase(orders_created_total[1h])) by (type)", "legendFormat": "{{type}}" }
      ]
    },
    {
      "id": 6,
      "title": "Orders resolved/hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "sum(increase(orders_resolved_total[1h])) by (outcome)", "legendFormat": "{{outcome}}" }
      ]
    }
  ]
}
